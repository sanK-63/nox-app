{
  "name": "my-tasks",
  "version": "2.0.0",
  "description": "Nox Task Manager — кроссплатформенный таск-менеджер с таймлайном, календарём и Google Sync",
  "author": "sanK-63",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.nox.app",
    "productName": "Nox Task Manager",
    "directories": {
      "output": "C:\\nox-release"
    },
    "npmRebuild": false,
    "compression": "store",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      ".env"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Nox Task Manager"
    }
  },
  "dependencies": {
    "app-builder-bin": "^4.2.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "react": "^19.2.5",
    "react-calendar": "^6.0.1",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "asar": "^3.2.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
